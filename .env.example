# Copy to .env and fill in. NEVER commit the real .env.
# All secrets are loaded via src/utils/secrets.py and never logged.

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- Database ---
DB_PATH=./data/trading.db

# --- Data ingestion ---
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=3

# --- Telegram (Week 6) ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to receive alerts (allowlist)
TELEGRAM_CHAT_ID_ALLOWLIST=

# ---------------------------------------------------------------------------
# Angel One SmartAPI -- READ-ONLY market data (Week 5+)
# ---------------------------------------------------------------------------
# This integration is DATA ONLY: it pulls live LTPs and EOD bars to enrich
# yfinance / BhavCopy. NO ORDER PLACEMENT happens from these credentials in
# the current codebase. Do NOT reuse these env vars for live execution
# without a full security review (SEBI retail-algo compliance, employer
# policy sign-off, hardware MFA on the trading account).
#
# How to get the values:
# 1. Log in at https://smartapi.angelbroking.com/
# 2. Click "Create New App". Give it any name; redirect URL can be
#    http://localhost (we don't use the OAuth callback).
# 3. Copy the API Key shown after registration -> ANGEL_API_KEY.
# 4. Your Client ID is your Angel One trading login (e.g. A12345)
#    -> ANGEL_CLIENT_CODE.
# 5. MPIN: the 4-digit PIN you set on the Angel One web/app for login.
#    -> ANGEL_MPIN.
# 6. TOTP secret: when you enabled 2FA on Angel One, it showed a QR code AND
#    the underlying base32 secret (e.g. "JBSWY3DPEHPK3PXP"). That STRING is
#    what we need (NOT the rolling 6-digit code). If you only saved the QR,
#    re-enable 2FA in Angel One settings and copy the secret this time.
#    -> ANGEL_TOTP_SECRET.
# 7. (Optional) ANGEL_API_SECRET is shown on the SmartAPI app dashboard and
#    is required by some endpoints -- safe to leave blank for getCandleData
#    and getLtpData.
#
# Security notes:
# - These four values together can place real orders. Treat the .env file
#   like a password vault: chmod 600 on Linux, restrict ACL on Windows.
# - The TOTP secret is the most sensitive: it bypasses the OTP step.
# - All five values are redacted by name in src/utils/logger.py before any
#   log line is written.
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=
ANGEL_API_SECRET=

# Hard kill-switch. Set ANGEL_ALLOW_ORDERS=true ONLY when you have
# explicitly wired the order-placement code (which the current codebase
# does not). The session module refuses to load order endpoints unless
# this flag is true, so leaving it false is a safety belt.
ANGEL_ALLOW_ORDERS=false

# --- Validation thresholds ---
CROSS_SOURCE_CLOSE_TOLERANCE_PCT=0.10
CROSS_SOURCE_VOLUME_TOLERANCE_PCT=2.00

# ---------------------------------------------------------------------------
# Web dashboard (Phase A: local; Phase C: deployed behind Cloudflare Tunnel)
# ---------------------------------------------------------------------------
# The dashboard reads from the SAME SQLite DB used by the daily pipeline
# and exposes a phone-friendly view at http://localhost:8000 (or, after
# deployment, at your Cloudflare Tunnel URL). It's read-only: nothing the
# browser can do mutates the database.
#
# Single-user auth. Plaintext password lives in this .env (which is
# gitignored AND should be chmod 600 / restricted ACL). Compared in
# constant-time with `secrets.compare_digest` to stop timing attacks.
# Generate a fresh strong password once:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# Pick a username that's NOT 'admin' (slows down credential-stuffing).
WEB_USERNAME=
WEB_PASSWORD=

# Used by itsdangerous to sign the session cookie. Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotating this value invalidates every existing session immediately.
WEB_SESSION_SECRET=

# Bind address. 127.0.0.1 = local-only (recommended for laptop dev).
# 0.0.0.0 = listen on all interfaces (use ONLY behind Cloudflare Tunnel
# or a reverse proxy that terminates TLS).
WEB_BIND_HOST=127.0.0.1
WEB_BIND_PORT=8000

# ---------------------------------------------------------------------------
# Notifications (daily report via Email + WhatsApp)
# ---------------------------------------------------------------------------

# --- Email (Gmail recommended) ---------------------------------------------
# Use a Gmail App Password, NOT your real password.
# Steps: Google Account -> Security -> 2-Step Verification -> App Passwords.
# Generate one for "Mail / Other" and paste below as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
# Comma-separated recipients
EMAIL_TO=

# --- WhatsApp via CallMeBot (free, personal use) ---------------------------
# 1. Save +34 644 51 95 23 as a contact in your phone (e.g. "CallMeBot").
# 2. From your phone, send "I allow callmebot to send me messages" to that number.
# 3. You will receive an APIKEY in reply. Paste it below.
# 4. CALLMEBOT_PHONE is your full number with country code, NO leading + or 00.
#    Example for India: 919876543210
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# --- WhatsApp via Twilio (optional, paid; leave blank to disable) ----------
# Use Twilio if you need delivery to multiple recipients or production-grade SLA.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_WHATSAPP=
TWILIO_TO_WHATSAPP=
